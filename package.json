{
  "name": "swagify-automation",
  "version": "1.0.0",
  "description": "Playwright automation framework for Swagify ecommerce flows.",
  "private": true,
  "scripts": {
    "test": "cross-env TEST_ENV=production playwright test",
    "test:production": "cross-env TEST_ENV=production playwright test --grep @smoke",
    "test:ci": "cross-env CI=true TEST_ENV=production playwright test --grep @smoke --headed",
    "test:checkout": "cross-env CI=true TEST_ENV=production playwright test tests/e2e/checkout.spec.ts --headed",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "dashboard": "node scripts/generate-dashboard.js",
    "posttest": "node scripts/generate-dashboard.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "typescript": "^5.9.3"
  }
}
